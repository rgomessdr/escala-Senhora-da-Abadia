rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(data) { return isSignedIn() && data.ownerId == request.auth.uid; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Validation Blueprints ---
    function isValidServer(data) {
      return data.keys().hasAll(['name', 'type', 'active', 'ownerId']) &&
             data.keys().size() == 4 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.type in ['acolito', 'coroinha'] &&
             data.active is bool &&
             data.ownerId == request.auth.uid;
    }

    function isValidMass(data) {
      return data.keys().hasAll(['title', 'date', 'time', 'location', 'assignments', 'ownerId']) &&
             data.title is string && data.title.size() > 0 &&
             data.date is string &&
             data.time is string &&
             data.location is string &&
             data.ownerId == request.auth.uid &&
             data.assignments is map;
    }

    // --- Collection Rules ---

    match /servers/{serverId} {
      allow get: if isOwner(existing());
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      
      allow create: if isSignedIn() && isValidServer(incoming());
      
      allow update: if isOwner(existing()) && isValidServer(incoming());
      
      allow delete: if isOwner(existing());
    }

    match /masses/{massId} {
      allow get: if isOwner(existing());
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;

      allow create: if isSignedIn() && isValidMass(incoming());

      allow update: if isOwner(existing()) && isValidMass(incoming());

      allow delete: if isOwner(existing());
    }
  }
}
